#: selfprivacy_api/exceptions/__init__.py:12
msgid ""
"Your SelfPrivacy app is out of date, please update it to use new features."
msgstr ""
"La tua app SelfPrivacy non è aggiornata: ti invitiamo ad aggiornarla per "
"poter utilizzare le nuove funzionalità."

#: selfprivacy_api/exceptions/__init__.py:16
msgid ""
"Please report it to our support chats:\n"
"#chat:selfprivacy.org on Matrix or @selprivacy_chat on Telegram."
msgstr ""
"Ti preghiamo di segnalarlo nelle nostre chat di assistenza:\n"
"#chat:selfprivacy.org su Matrix o @selprivacy_chat su Telegram."

#: selfprivacy_api/exceptions/__init__.py:21
msgid ""
"Kanidm is the identity and authentication service that manages users and "
"access to services."
msgstr ""
"Kanidm è il servizio di gestione delle identità e di autenticazione che "
"gestisce gli utenti e l'accesso ai servizi."

#: selfprivacy_api/exceptions/__init__.py:25
msgid ""
"In some cases, a Kanidm update may introduce breaking changes affecting the "
"API, CLI commands, or configuration compatibility."
msgstr ""
"In alcuni casi, un aggiornamento di Kanidm può comportare modifiche "
"sostanziali che incidono sull'API, sui comandi CLI o sulla compatibilità "
"della configurazione."

#: selfprivacy_api/exceptions/__init__.py:29
msgid ""
"Console commands to debug:\n"
"    'systemctl status kanidm.service'\n"
"    'journalctl -u kanidm.service'\n"
msgstr ""
"Comandi console per eseguire il debug:\n"
"    'systemctl status kanidm.service'\n"
"    'journalctl -u kanidm.service'\n"

#: selfprivacy_api/exceptions/__init__.py:47
msgid "The API is using the wrong user repository."
msgstr "L'API sta utilizzando il repository utenti sbagliato."

#: selfprivacy_api/exceptions/services.py:26
#, python-format
msgid "No such service: %(service_id)s. %(REPORT_IT_TO_SUPPORT_CHATS)s"
msgstr ""
"Servizio non disponibile: %(service_id)s. %(REPORT_IT_TO_SUPPORT_CHATS)s"

#: selfprivacy_api/exceptions/services.py:46
#, python-format
