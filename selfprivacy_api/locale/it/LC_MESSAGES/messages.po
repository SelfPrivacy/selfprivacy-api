"Fuso orario non valido: %(timezone)s\n"
"Fuso orario non presente in pytz.all_timezones.\n"
"Lista dei fusi orari disponibili:\n"
"https://data.iana.org/time-zones/data/zone.tab"

#: selfprivacy_api/exceptions/system.py:91
#, python-format
msgid ""
"%(description)s\n"
"%(REPORT_IT_TO_SUPPORT_CHATS)s\n"
"Command: %(command)s\n"
"Used regex pattern: %(regex_pattern)s\n"
"Data: %(data)s"
msgstr ""
"%(description)s\n"
"%(REPORT_IT_TO_SUPPORT_CHATS)s\n"
"Comando: %(command)s\n"
"Modello di espressione regolare utilizzato: %(regex_pattern)s\n"
"Dati: %(data)s"

#: selfprivacy_api/exceptions/tokens.py:22
msgid "Access token was not found."
msgstr "Non è stato trovato alcun token di accesso."

