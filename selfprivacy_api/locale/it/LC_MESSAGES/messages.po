#: selfprivacy_api/exceptions/system.py:33
#, python-format
msgid ""
"Command execution failed.\n"
"%(description)s\n"
"%(REPORT_IT_TO_SUPPORT_CHATS)s\n"
"Executed command: %(command)s\n"
"Output: %(output)s"
